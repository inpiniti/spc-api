# API 서버
PORT=3000

# 인증
JWT_SECRET=spc-dev-secret-change-me
JWT_EXPIRES=12h

# Gateway 전용 인증 키 (spc-gateway 의 GATEWAY_KEY 와 동일해야 함)
GATEWAY_KEY=gw_secret_key_change_me

# 명령 큐 기본 만료(초) — dial-in 주기를 고려해 pending 명령을 만료시킨다
COMMAND_TTL_SEC=3600

# PostgreSQL
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=spcdb
PGUSER=spc
PGPASSWORD=1234
